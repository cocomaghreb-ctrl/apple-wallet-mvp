# Database
DATABASE_URL="postgresql://wallet_user:wallet_pass@localhost:5432/apple_wallet_db"

# API
API_PORT=3001
API_ENV=development
NODE_ENV=development
API_SECRET_KEY=your-super-secret-key-change-in-production

# JWT/Auth
JWT_SECRET=your-jwt-secret-key-min-32-chars-change-production
JWT_EXPIRE_IN=7d

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Apple Wallet Configuration
APPLE_TEAM_ID=your-team-id
APPLE_PASS_TYPE_ID=pass.com.example.loyaltycard

# Apple Push Notification Service (APNs)
APPLE_APN_KEY_ID=your-key-id
APPLE_APN_TEAM_ID=your-team-id
APPLE_APN_BUNDLE_ID=com.example.loyaltycard
APPLE_APN_ENVIRONMENT=sandbox

# Organization Info
ORGANIZATION_NAME=My Organization
ORGANIZATION_CONTACT_EMAIL=contact@example.com
ORGANIZATION_WEBSITE=https://example.com

# Pass Configuration
PASS_GENERATION_MODE=development
